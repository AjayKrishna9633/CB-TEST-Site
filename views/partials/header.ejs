<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="UserVault — Securely manage your profile and addresses">
    <title><%= title %> | UserVault</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-logo">UserVault</a>
            <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
                <span></span><span></span><span></span>
            </button>
            <ul class="nav-links" id="navLinks">
                <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                    <li><a href="/dashboard">Dashboard</a></li>
                    <% if (currentUser.role === 'admin') { %>
                        <li><a href="/admin">Admin Panel</a></li>
                    <% } %>
                    <li><a href="/logout" class="btn btn-outline btn-sm">Logout</a></li>
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/register" class="btn btn-primary btn-sm">Register</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <!-- Flash Messages -->
    <div class="flash-container">
        <% if (typeof success_msg !== 'undefined' && success_msg) { %>
            <% if (Array.isArray(success_msg)) { %>
                <% success_msg.forEach(function(msg) { if (msg && msg.length > 0) { %>
                    <div class="alert alert-success" role="alert">
                        <span class="alert-icon">✓</span>
                        <%= msg %>
                        <button class="alert-close" aria-label="Close">×</button>
                    </div>
                <% } }) %>
            <% } else if (success_msg.length > 0) { %>
                <div class="alert alert-success" role="alert">
                    <span class="alert-icon">✓</span>
                    <%= success_msg %>
                    <button class="alert-close" aria-label="Close">×</button>
                </div>
            <% } %>
        <% } %>

        <% if (typeof error_msg !== 'undefined' && error_msg) { %>
            <% if (Array.isArray(error_msg)) { %>
                <% error_msg.forEach(function(msg) { if (msg && msg.length > 0) { %>
                    <div class="alert alert-error" role="alert">
                        <span class="alert-icon">!</span>
                        <%= msg %>
                        <button class="alert-close" aria-label="Close">×</button>
                    </div>
                <% } }) %>
            <% } else if (error_msg.length > 0) { %>
                <div class="alert alert-error" role="alert">
                    <span class="alert-icon">!</span>
                    <%= error_msg %>
                    <button class="alert-close" aria-label="Close">×</button>
                </div>
            <% } %>
        <% } %>
    </div>

    <main class="main-content">
